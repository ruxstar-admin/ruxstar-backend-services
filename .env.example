MONGODB_URI=mongodb://localhost:27017
PORT=3000
JWT_SECRET=change_this_secret
NODE_ENV=development

MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=RUXSTR
MSG91_TEMPLATE_ID=your_otp_template_id
OTP_EXPIRY_MINUTES=10

# NODE_ENV=development skips real SMS; OTP returned in signup send-otp response

# Cashfree Secure ID (vendor KYC)
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ENV=sandbox
CASHFREE_API_VERSION=2024-12-01
# Optional: for production 2FA public-key auth
# CASHFREE_SIGNATURE=
# Frontend URL — DigiLocker redirects here after consent (must be https)
KYC_REDIRECT_URL=https://ruxstar.com/kyc/done

# GCP: store CASHFREE_CLIENT_ID + CASHFREE_CLIENT_SECRET in Secret Manager
# (see cloudbuild.yaml — cashfree-client-id, cashfree-client-secret)
