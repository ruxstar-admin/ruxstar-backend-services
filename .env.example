MONGODB_URI=mongodb://localhost:27017
PORT=3000
JWT_SECRET=change_this_secret
NODE_ENV=development

MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=RUXSTR
MSG91_TEMPLATE_ID=your_otp_template_id
OTP_EXPIRY_MINUTES=10

# NODE_ENV=development skips real SMS; OTP returned in signup send-otp response

# Cashfree Secure ID (vendor KYC)
CASHFREE_CLIENT_ID=
CASHFREE_CLIENT_SECRET=
CASHFREE_ENV=production
CASHFREE_API_VERSION=2024-12-01
# Optional: for production 2FA public-key auth
# CASHFREE_SIGNATURE=
# GCP Cloud Run: set via cloudbuild trigger substitution _KYC_REDIRECT_URL
KYC_REDIRECT_URL=https://ruxstar.com/kyc/done

# GCP Cloud Storage — business setup photos (private bucket)
GCS_BUCKET=ruxstar-photos
# Leave unset for private buckets — photos are served via the backend photo API
# GCS_PUBLIC_BASE_URL=
# Production: full Cloud Run URL so <img> tags load photos directly from the backend
API_PUBLIC_BASE_URL=https://ruxstar-backend-services-391710984982.us-central1.run.app

# (see cloudbuild.yaml — cashfree-client-id, cashfree-client-secret)

# Cashfree Payment Gateway (customer booking payments) — separate product/credentials from KYC above.
CASHFREE_PG_CLIENT_ID=
CASHFREE_PG_SECRET=
CASHFREE_PG_ENV=sandbox
CASHFREE_PG_API_VERSION=2023-08-01
# Public HTTPS URL Cashfree calls after payment (must match dashboard webhook URL).
CASHFREE_PG_NOTIFY_URL=https://your-backend.run.app/webhooks/cashfree/payments
# After checkout, Cashfree redirects here; {bookingId} is replaced before order create.
CASHFREE_PG_RETURN_URL=https://ruxstar.com/customer/payment-status?bookingId={bookingId}
BOOKING_HOLD_MINUTES=20
BOOKING_REFUND_WINDOW_HOURS=24
# (see cloudbuild.yaml — cashfree-pg-client-id, cashfree-pg-secret)
